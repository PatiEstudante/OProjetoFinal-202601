    <worksheet name='card inadimplencia'>
      <table>
        <view>
          <datasources>
            <datasource caption='todas as variaveis+ (Múltiplas conexões)' name='federated.0laowdb1lgt3ev0zq2aog1e38qfv' />
          </datasources>
          <datasource-dependencies datasource='federated.0laowdb1lgt3ev0zq2aog1e38qfv'>
            <column caption='Indicador inadimplencia' datatype='string' name='[Indicador desemprego (cópia)_0920349517877257]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [diferenca (cópia)_0920349518528522] &gt; 0&#13;&#10;  THEN &quot;▲ &quot; + STR(ROUND([diferenca (cópia)_0920349518528522], 2))&#13;&#10;ELSEIF [diferenca (cópia)_0920349518528522] &lt; 0&#13;&#10;  THEN &quot;▼ &quot; + STR(ROUND(ABS([diferenca (cópia)_0920349518528522]), 2))&#13;&#10;ELSE &quot;— 0&quot;&#13;&#10;END' />
            </column>
            <column caption='Ultimo valor - inadimplencia' datatype='real' name='[Ultimo valor - desemprego (cópia)_0920349517668360]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [periodo] = {FIXED : MAX([periodo])}&#13;&#10;THEN [media_inadimplencia]&#13;&#10;END' />
            </column>
            <column caption='diferenca inad' datatype='real' name='[diferenca (cópia)_0920349518528522]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED : MAX(IF [periodo] = {FIXED : MAX([periodo])}&#13;&#10;  THEN [media_inadimplencia] END)}&#13;&#10;-&#13;&#10;{FIXED : MAX(IF [periodo] = {FIXED : MAX(&#13;&#10;  IF [periodo] &lt; {FIXED : MAX([periodo])} THEN [periodo] END)}&#13;&#10;  THEN [media_inadimplencia] END)}' />
            </column>
            <column caption='Media Inadimplencia' datatype='real' name='[media_inadimplencia]' role='measure' type='quantitative' />
            <column-instance column='[Indicador desemprego (cópia)_0920349517877257]' derivation='None' name='[none:Indicador desemprego (cópia)_0920349517877257:nk]' pivot='key' type='nominal' />
            <column caption='Periodo' datatype='date' name='[periodo]' role='dimension' type='ordinal' />
            <column-instance column='[Ultimo valor - desemprego (cópia)_0920349517668360]' derivation='Sum' name='[sum:Ultimo valor - desemprego (cópia)_0920349517668360:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style>
